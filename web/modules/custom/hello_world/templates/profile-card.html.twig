{# templates/profile-card.html.twig #}
<div class="flex flex-col gap-4 p-6 bg-slate-900 rounded-2xl shadow-xl border border-slate-800 transition-all duration-300 hover:scale-[1.02] hover:border-rose-500/30">
  
  {# 1. Render the SVG markup #}
  {% if icon %}
    <div class="w-12 h-12 text-rose-400 bg-rose-500/10 rounded-xl flex items-center justify-center border border-rose-500/20">
      {{ icon|raw }}
    </div>
  {% endif %}

  {# 2. Title String #}
  <h3 class="text-xl font-extrabold text-white tracking-tight mt-2">
    {{ title }}
  </h3>

  {# 3. Render the processed body #}
  {% if body %}
    <div class="text-slate-400 text-sm leading-relaxed font-medium">
      {{ body|raw }}
    </div>
  {% endif %}

</div>
